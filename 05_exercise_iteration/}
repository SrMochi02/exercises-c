#include <stdio.h>

int main (void) {

	int start_value = 0;
	int limit_value = 0;
	int divisor_value = 0;


	printf("Enter the upper limit:\n");
	scanf("%d", &limit_value);

	printf("Enter the divisor:\n");
	scanf("%d", &divisor_value);

	if(limit_value == 0 || divisor_value == 0) {
		printf("Please insert a valid number\n");
	}
	else {
		for(start_value = 0; start_value <= limit_value; start_value += divisor_value) {


			printf("The dividend number:%d\n", start_value);
			printf("The divisor:%d\n", divisor_value);
		}
	}
	return 0;


}
